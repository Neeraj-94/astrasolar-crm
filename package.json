{
  "name": "astrasolar-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "npm run db:migrate --workspace=@astra/api",
    "db:seed": "npm run db:seed --workspace=@astra/api",
    "db:import-products": "npm run db:import-products --workspace=@astra/api",
    "db:clear-products": "npm run db:clear-products --workspace=@astra/api",
    "db:studio": "npm run db:studio --workspace=@astra/api"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
