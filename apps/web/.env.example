# =========================================================================
# AstraSolar CRM - Environment Variables
# Copy this file to `.env.local` and fill in the real values.
# DO NOT commit .env.local. Add Netlify env vars in the dashboard.
# =========================================================================

# ---- PostgreSQL ---------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/astrasolar?schema=public"

# ---- Firebase (CLIENT) --------------------------------------------------
# Find these in Firebase Console -> Project Settings -> General -> Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ---- Firebase (ADMIN / SERVER) ------------------------------------------
# Service account JSON from Firebase Console -> Project Settings -> Service accounts.
# Either paste the full JSON string as one line OR provide a path to a JSON file.
# IMPORTANT: keep \n inside the private key as the literal characters \n.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ---- App ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SESSION_COOKIE_NAME="__astra_session"
SESSION_COOKIE_MAX_AGE="432000" # 5 days, in seconds
