"use client";

import { useEffect, useMemo, useState } from "react";
import { useRouter } from "next/navigation";
import { useApi } from "@/lib/api/use-api";
import { apiPatch } from "@/lib/api/client";

/**
 * No Answers tab — a faithful reproduction of the astrasolar-app
 * "📞 No Answer Leads" tab (same structure and UI): the source dark-theme
 * palette and `.lg-leads-table` styling are scoped locally, the header carries
 * a search box + lead count, a toggle-button filter bar opens a checkbox panel,
 * saved filter presets persist per browser, and the wide 15-column table is
 * rendered exactly as in the source (Outcome dropdown, Notes textarea,
 * Dials −/+, Last Called date + Today, Original Slot, Status, Rebook).
 */

interface LeadRow {
  id: string;
  company: string; // "ASTRA" | "DC"
  stage: string;
  outcome: string | null;
  disposition: string | null;
  source: string | null;
  timestamp: string;
  consultantNotes: string | null;
  leadGenNotes: string | null;
  firstName: string;
  surName: string;
  phone?: string | null;
  email?: string | null;
  address?: string | null;
  postCode?: string | null;
  state?: string | null;
  billSpend?: string | null;
  dials?: number | null;
  bookingDate?: string | null;
  bookingTime?: string | null;
  leadGen?: { id: string; name: string } | null;
  consultant?: { id: string; name: string } | null;
}

// --- enum → friendly label maps (mirror the source DISPOSITIONS list) --------

/** Outcome dropdown options — editable disposition (matches source Outcome). */
const DISPOSITIONS: { val: string; label: string }[] = [
  { val: "", label: "(no outcome)" },
  { val: "SOLD", label: "Sold" },
  { val: "PRES_PROP_CREATED", label: "Pres / Prop Created" },
  { val: "CALL_BACK", label: "Call Back" },
  { val: "RESCHEDULE", label: "Reschedule" },
  { val: "BEEN_RESCHEDULED", label: "Been Rescheduled" },
  { val: "NO_ANSWER", label: "No Answer" },
  { val: "NOT_INTERESTED", label: "Not Interested" },
  { val: "DNQ", label: "DNQ" },
  { val: "CANCELLED", label: "Cancel" },
];

const DISP_LABELS: Record<string, string> = Object.fromEntries(
  DISPOSITIONS.filter((d) => d.val).map((d) => [d.val, d.label]),
);

const SOURCE_LABELS: Record<string, string> = {
  BLOOM_ASTRA: "Bloom Astra",
  REFERRAL: "Referral",
  INBOUND: "Inbound",
  WEBSITE: "Website",
  BRIGHTE: "Brighte",
};

/** Consultant Disposition cell colour — mirrors the source colour map. */
function consultantDispColor(val: string | null): string {
  switch (val) {
    case "CANCELLED":
    case "DNQ":
    case "NOT_INTERESTED":
      return "var(--red)";
    case "RESCHEDULE":
    case "BEEN_RESCHEDULED":
      return "var(--gold)";
    case "NO_ANSWER":
      return "var(--text-dim)";
    default:
      return "var(--text-dim)";
  }
}

const DAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const MONTHS = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

function originalDateLabel(iso: string | null | undefined): string {
  if (!iso) return "";
  const d = new Date(`${iso}T12:00:00`);
  if (Number.isNaN(d.getTime())) return iso;
  return `${DAYS[d.getDay()]} ${d.getDate()} ${MONTHS[d.getMonth()]}`;
}

function timeAgo(iso: string | null | undefined): string {
  if (!iso) return "";
  const mins = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
  if (Number.isNaN(mins)) return "";
  if (mins < 60) return `${mins}m ago`;
  if (mins < 1440) return `${Math.floor(mins / 60)}h ago`;
  return `${Math.floor(mins / 1440)}d ago`;
}

function todayISO(): string {
  return new Date().toISOString().slice(0, 10);
}

// --- filter facets -----------------------------------------------------------

type Facet = "rep" | "consultant" | "status" | "source" | "outcome" | "consultantDisp";
type FilterState = Record<Facet, string[]>;

const EMPTY_FILTERS: FilterState = {
  rep: [], consultant: [], status: [], source: [], outcome: [], consultantDisp: [],
};

const FACET_TITLES: Record<Facet, string> = {
  rep: "Lead Gen Rep",
  consultant: "Consultant",
  status: "Status",
  source: "Source",
  outcome: "Outcome",
  consultantDisp: "Consultant Disposition",
};

function facetValue(l: LeadRow, facet: Facet): string {
  switch (facet) {
    case "rep":
      return l.leadGen?.name || "(unknown)";
    case "consultant":
      return l.consultant?.name || "(unknown)";
    case "status":
      return "pending";
    case "source":
      return l.source || "(unknown)";
    case "outcome":
      return l.disposition || "";
    case "consultantDisp":
      return l.disposition || "";
  }
}

function facetDisplay(facet: Facet, val: string): string {
  if (facet === "outcome") return val === "" ? "(no outcome)" : DISP_LABELS[val] ?? val;
  if (facet === "consultantDisp") return val === "" ? "(none)" : DISP_LABELS[val] ?? val;
  if (facet === "source") return SOURCE_LABELS[val] ?? val;
  return val;
}

// --- saved presets (per-browser, localStorage) -------------------------------

interface Preset {
  name: string;
  q: string;
  filters: FilterState;
}

const PRESETS_KEY = "na-filter-presets";

function loadPresets(): Preset[] {
  if (typeof window === "undefined") return [];
  try {
    const raw = window.localStorage.getItem(PRESETS_KEY);
    return raw ? (JSON.parse(raw) as Preset[]) : [];
  } catch {
    return [];
  }
}

function persistPresets(p: Preset[]) {
  if (typeof window === "undefined") return;
  try {
    window.localStorage.setItem(PRESETS_KEY, JSON.stringify(p));
  } catch {
    /* ignore */
  }
}

// Local-only field overrides (Dials / Notes / Last Called have no v2 endpoint).
interface Override {
  dials?: number;
  notes?: string;
  lastCalled?: string;
}

