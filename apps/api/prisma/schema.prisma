// ============================================================================
//  CRM — Prisma Schema
//  Stack: PostgreSQL + Prisma (NestJS backend)
//
//  Covers:
//    - RBAC with runtime-editable roles (Role/Permission as DATA, not enum)
//    - Multi-role users (a user holds many roles; access = UNION of grants)
//    - Leads with a TWO-STAGE disposition model (intake -> post-booking)
//      (customer details are flattened onto the Lead — no separate Contact)
//    - Bookings as first-class records (consultant + who booked it)
//    - Sales as SEPARATE entities, born when a consultation is SOLD
//    - Installations (narrow Tier-3 roles)
//    - Disposition history + audit log (fuel for analytics + future AI)
//
//  Access rules live as PERMISSION DATA + a getEffectivePermissions() /
//  getVisibilityScope() policy in NestJS. See permission-matrix.md for the
//  full capability list and role mapping. pgvector embeddings (future AI
//  phase) are added later via a raw migration, not here.
// ============================================================================

generator client {
  provider = "prisma-client-js"
  // Dedicated output so the API client does NOT collide with the legacy web
  // app's Prisma client (both default to node_modules/.prisma/client). The API
  // imports this via the `src/db.ts` barrel.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
//  RBAC — roles & permissions as runtime-editable DATA
//
//    - Permission.key vocabulary is fixed in code (something must ENFORCE each
//      key), but admins compose Roles from that vocabulary at runtime.
//    - A user holds many roles (UserRole). Effective access = UNION of all
//      permissions across all their roles ("union always wins").
//    - The 10 built-in roles are SEED DATA, flagged isSystem so they can't be
//      deleted. Admins may create additional roles.
// ============================================================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String                          // bcrypt hash
  name          String
  isActive      Boolean  @default(true)
  region        String?                          // home region ("ACT" | "TAS" | ...) — drives consultant grouping in availability/schedule
  aliases       String[] @default([])            // alternate names used to recognise/match the user (e.g. Bloome setter names)
  avatarUrl     String?                          // profile photo URL (storage handled by the web app)
  phones        Json?                            // [{ label, number, isPrimary }] — self-managed contact numbers

  // Team membership / management (drives manager-level visibility scope)
  teamId        String?
  team          Team?    @relation("TeamMembers", fields: [teamId], references: [id])
  managedTeam   Team?    @relation("TeamManager")

  refreshToken  String?                          // hashed refresh token

  // Welcome-email support. `welcomePassword` retains the plaintext temp password
  // set at creation (or admin reset) so a super admin can manually (re)send the
  // welcome email from the Users tab. Cleared once the user changes their own
  // password. `welcomeEmailSentAt` records the last successful send (UI hint).
  welcomePassword    String?
  welcomeEmailSentAt DateTime?

  // Roles (many-to-many)
  roles         UserRole[]

  // Domain relations
  leadGenLeads    Lead[]        @relation("LeadGen")
  consultantLeads Lead[]        @relation("LeadConsultant")
  consultations Booking[]       @relation("Consultant")
  bookingsMade  Booking[]       @relation("BookedBy")
  ownedSales    Sale[]          @relation("SaleOwner")
  customer      Customer?                                  // self-service customer profile (Customer dashboard)
  handledIssues PostInstallIssue[] @relation("IssueHandler")
  activities    Activity[]
  installs      Installation[]  @relation("Installer")
  availabilitySlots        AvailabilitySlot[]       @relation("ConsultantAvailability")
  availabilitySubmissions  AvailabilitySubmission[] @relation("ConsultantAvailabilitySubmissions")
  scheduleAppointments     Appointment[]            @relation("ConsultantScheduleAppointments")
  taskAssignments          TaskCard[]               @relation("TaskAssignee")
  tasksCreated             TaskCard[]               @relation("TaskCreator")
  taskNudgesSent           TaskCard[]               @relation("TaskNudger")
  taskComments             TaskComment[]            @relation("TaskCommentAuthor")
  notifications            Notification[]           @relation("UserNotifications")
  checklistsCreated        LeadChecklist[]          @relation("ChecklistCreatedBy")
  consultantContact        ConsultantContact?       @relation("ConsultantContact")

  sortOrder     Int?                             // manual drag-and-drop row order (null = default sort)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teamId])
}

// Per-consultant callback number + ClickSend sender ID, one pair per brand
// (Astra Solar / DC Solar). Ported from the astrasolar-app Firebase node
// `/consultantContacts/{consultantId}`. A null/empty field means "fall back to
// the system default" for that brand. Managed in Leads → Consultant Contacts;
// consumed by the SMS sender resolver (brand derived from the lead's company).
model ConsultantContact {
  id           String @id @default(uuid())
  consultantId String @unique
  consultant   User   @relation("ConsultantContact", fields: [consultantId], references: [id], onDelete: Cascade)

  // Astra Solar
  contactPhoneAstra String?
  senderIdAstra     String?
  // DC Solar
  contactPhoneDc String?
  senderIdDc     String?

  // Light audit trail surfaced in the UI ("Last updated … by …").
  updatedById   String?
  updatedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consultantId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  managerId String?  @unique
  manager   User?    @relation("TeamManager", fields: [managerId], references: [id])
  members   User[]   @relation("TeamMembers")
  createdAt DateTime @default(now())
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique          // "Super Admin", "Sales Manager", ...
  description String?
  isSystem    Boolean          @default(false)   // protect the 10 built-in roles
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique           // "leads:read:team", "system:admin", ...
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ============================================================================
//  LEADS — two-stage status model
//
//    stage        : where in the journey (drives which tab/board)
//    outcome      : LEAD-GEN's result at the intake stage
//    disposition  : SALES CONSULTANT's result at the post-booking stage
//
//  Triggers (each a single DB transaction):
//    outcome     -> BOOKED : create Booking, stage -> BOOKED
//    disposition -> SOLD   : create Sale,    stage -> CONVERTED
// ============================================================================

model Lead {
  id            String             @id @default(uuid())          // leadId
  timestamp     DateTime           @default(now())               // when the lead was entered

  // Contact details — flattened directly onto the lead
  firstName     String
  surName       String
  phone         String?
  email         String?
  address       String?
  postCode      String?
  state         String?

  billSpend     String?                                          // bill-spend band as text ("$251-$500", ...)
  code          String?                                          // campaign code ("ACT-1", ...)

  // Ownership — the lead carries the LATEST state directly, kept in sync with the
  // newest LeadStateLog row (same transaction). The lead is the current truth.
  leadGenId     String                                           // latest lead-gen assigned to the lead
  leadGen       User               @relation("LeadGen", fields: [leadGenId], references: [id])
  consultantId  String?                                          // latest consultant booked to the lead (mirrors booking)
  consultant    User?              @relation("LeadConsultant", fields: [consultantId], references: [id])

  source        LeadSource         @default(BLOOM_ASTRA)         // leadSource
  outcome       LeadOutcome?                                     // lead-gen result (intake)
  disposition   SalesDisposition?                                // consultant result (post-booking)

  dials         Int                @default(0)                   // call attempts (can be added/subtracted)

  leadGenNotes    String?
  consultantNotes String?

  company       Company            @default(ASTRA)               // DC | Astra (defaults to Astra)

  // Booking — denormalized onto the lead for the board (mirrors the Booking record)
  bookingDate   DateTime?          @db.Date
  bookingTime   String?

  // --- structural fields retained so the rest of the schema stays intact ---
  stage         LeadStage          @default(INTAKE)
  booking       Booking?
  convertedAt   DateTime?
  sale          Sale?
  checklist     LeadChecklist?                                   // per-lead system-recommendation checklist (1:1)

  stateLog      LeadStateLog[]                                   // any change to the fields above is logged here
  activities    Activity[]
  scheduleAppointments Appointment[] @relation("LeadScheduleAppointments")

  sortOrder     Int?                                             // manual drag-and-drop row order (null = default sort)
  updatedAt     DateTime           @updatedAt

  // Blacklist enforcement (Leads -> Blacklist Leads). Set true by the sweep
  // when this lead matches a BlacklistEntry; filtered out of the No Answers tab.
  blacklisted     Boolean   @default(false)
  blacklistedAt   DateTime?
  blacklistEntryId String?

  @@index([stage])
  @@index([leadGenId])
  @@index([consultantId])
  @@index([outcome])
  @@index([disposition])
  @@index([source])
  @@index([company])
  @@index([phone])
  @@index([surName])
}

// Where the lead came from ("leadSource").
enum LeadSource {
  BLOOM_ASTRA       // "Bloom Astra"
  REFERRAL
  INBOUND
  WEBSITE
  BRIGHTE
}

// Our internal brand/business entity the lead/sale belongs to. Reporting label
// only — does NOT affect visibility (everyone sees both companies).
enum Company {
  ASTRA
  DC
}

enum LeadStage {
  INTAKE
  BOOKED
  CONVERTED
  CLOSED
}

// Lead-gen's intake result ("outcome").
enum LeadOutcome {
  APPOINTMENT       // -> triggers Booking + stage = BOOKED
  HOT_CALL_BACK     // "Hot Call Back"
  NO_ANSWER
  NOT_INTERESTED
  DNQ
  ALREADY_HAS_SOLAR // "Already has Solar"
  WRONG_NUMBER      // "Wrong Number"
  RESCHEDULE
}

// Sales consultant's post-booking result ("disposition").
enum SalesDisposition {
  SOLD              // -> triggers Sale + stage = CONVERTED
  PRES_PROP_CREATED // "Pres / Prop Created"
  CALL_BACK         // "Call Back"
  RESCHEDULE
  BEEN_RESCHEDULED  // "Been Rescheduled"
  NO_ANSWER
  NOT_INTERESTED
  DNQ
  CANCELLED
}

// ============================================================================
//  BOOKINGS — first-class records
// ============================================================================

model Booking {
  id              String    @id @default(uuid())
  leadId          String    @unique
  lead            Lead      @relation(fields: [leadId], references: [id])

  consultantId    String
  consultant      User      @relation("Consultant", fields: [consultantId], references: [id])

  bookedById      String
  bookedBy        User      @relation("BookedBy", fields: [bookedById], references: [id])

  scheduledAt     DateTime
  rescheduledFrom DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([consultantId])
  @@index([scheduledAt])
}

// ============================================================================
//  SALES — separate entity, own lifecycle, traces back to exactly one lead.
//  Closing/editing a sale is gated by OWNERSHIP (sales:manage:own), NOT by a
//  manager's team scope — only the owning consultant (break-glass: super admin)
//  may mark SOLD or edit the sale.
// ============================================================================

model Sale {
  id            String   @id @default(uuid())
  saleRef       String?  @unique                    // human-facing "saleID" (e.g. S-2026-0001)

  leadId        String   @unique                     // 1 lead -> at most 1 sale; customer data read via lead
  lead          Lead     @relation(fields: [leadId], references: [id])

  ownerId       String                               // owning consultant
  owner         User     @relation("SaleOwner", fields: [ownerId], references: [id])

  // Customer self-service link (powers the Customer dashboard).
  customer      Customer?

  // Core sale fields
  company       Company                              // carried from the lead (reporting label)
  status        SaleStatus @default(NEGOTIATION)     // overall lifecycle
  saleType      SaleType?                            // equipment combination
  systemType    SystemType?                          // install nature (new vs upgrade)
  energyProvider String?
  referral      String?

  // Money
  soldPrice     Decimal? @db.Decimal(12, 2)
  totalRRP      Decimal? @db.Decimal(12, 2)
  totalCommission Decimal? @db.Decimal(12, 2)

  // Dates
  saleDate      DateTime? @db.Date
  closedAt      DateTime?

  // Notes
  installNotes  String?

  // 1:1 detail blocks
  systemDetails       SystemDetails?
  statusDetails       SaleStatusDetails?
  installation        Installation?                  // installDetails (extended model)
  paymentDetails      PaymentDetails?
  commissioningDetails CommissioningDetails?

  // 1:n children
  extras         SaleExtra[]
  finance        SaleFinance[]
  postInstall    PostInstallIssue[]
  stageHistory   SaleStageHistory[]
  salesLog       SaleLog[]                           // general change log (any field change)
  rrpRequests    RrpRequest[]                        // pending custom-product RRP requests (finance)

  sortOrder     Int?                                // manual drag-and-drop row order (null = default sort)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([saleDate])
  @@index([company])
}

enum SaleStatus {
  NEGOTIATION
  CONTRACT
  ON_HOLD
  COMPLETED
  CANCELLED
}

// What equipment combination was sold. (UI may display "Solar + Battery".)
enum SaleType {
  SOLAR_ONLY
  BATTERY_ONLY
  SOLAR_BATTERY
}

// The nature of the install. (UI may display "Additional + Replacement".)
enum SystemType {
  NEW
  REPLACEMENT
  ADDITIONAL
  ADDITIONAL_REPLACEMENT
}

// ----- System specification (battery + solar + inverter + electrical) -------
// One-to-one with Sale. Nested groupings in the spec become field prefixes so
// every spec value stays a queryable column (commissions, sizes, STCs, etc.).
model SystemDetails {
  id            String  @id @default(uuid())
  saleId        String  @unique
  sale          Sale    @relation(fields: [saleId], references: [id])

  // Point-of-sale spec snapshots (what it cost/spec'd at the time).
  // Battery
  batteryBrand      String?
  batteryModel      String?
  batterySTC        Int?
  batteryModules    Int?                             // "modules"
  batterySize       Decimal? @db.Decimal(10, 2)      // "size" (kWh)
  batteryRRP        Decimal? @db.Decimal(12, 2)
  batteryCommission Decimal? @db.Decimal(12, 2)

  // Solar
  panelModel        String?
  panelWatt         Int?
  numPanels         Int?
  systemSize        Decimal? @db.Decimal(10, 2)      // kW
  solarRRP          Decimal? @db.Decimal(12, 2)
  solarSTC          Int?
  solarCommission   Decimal? @db.Decimal(12, 2)
  solarProfit       Decimal? @db.Decimal(12, 2)      // POS profit snapshot (from SolarProduct)
  batteryProfit     Decimal? @db.Decimal(12, 2)      // POS profit snapshot (from BatteryProduct)

  // Inverter + install/electrical
  inverterModel     String?
  inverterType      String?
  optimisers        Boolean?
  tilts             Int?
  roofType          String?
  storeys           Int?
  switchboard       String?
  nmi               String?                          // National Meter Identifier
  phase             String?                          // single / three phase

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ----- The 7 independent status fields, each a simple stage enum -----------
model SaleStatusDetails {
  id                  String     @id @default(uuid())
  saleId              String     @unique
  sale                Sale       @relation(fields: [saleId], references: [id])

  financeStatus       StageState @default(PENDING)
  preapprovalStatus   StageState @default(PENDING)
  meterChangeStatus   StageState @default(PENDING)
  installStatus       StageState @default(PENDING)
  paymentStatus       StageState @default(PENDING)
  commissioningStatus StageState @default(PENDING)
  cesStatus           StageState @default(PENDING)   // Clean Energy Scheme/Council, etc.

  updatedAt           DateTime   @updatedAt
}

enum StageState {
  PENDING
  IN_PROGRESS
  COMPLETED
  NOT_REQUIRED
}

// ----- Repeating line items -------------------------------------------------
model SaleExtra {
  id         String  @id @default(uuid())
  saleId     String
  sale       Sale    @relation(fields: [saleId], references: [id])
  itemName   String
  itemRef    String?                                 // "itemID" (external/catalog id)
  itemPrice  Decimal @db.Decimal(12, 2)
  profit     Decimal? @db.Decimal(12, 2)             // POS profit snapshot (from ExtraProduct)

  @@index([saleId])
}

// STUB — `finance[]` shape not yet specified. Placeholder fields; correct once
// the real financing structure is provided (lender, amount, term, rate...).
model SaleFinance {
  id         String  @id @default(uuid())
  saleId     String
  sale       Sale    @relation(fields: [saleId], references: [id])
  lender     String?
  amount     Decimal? @db.Decimal(12, 2)
  termMonths Int?
  status     StageState @default(PENDING)

  @@index([saleId])
}

// ----- Phase detail blocks --------------------------------------------------
model PaymentDetails {
  id           String   @id @default(uuid())
  saleId       String   @unique
  sale         Sale     @relation(fields: [saleId], references: [id])
  paymentNotes String?
  paymentDate  DateTime? @db.Date
  updatedAt    DateTime @updatedAt
}

model CommissioningDetails {
  id                 String   @id @default(uuid())
  saleId             String   @unique
  sale               Sale     @relation(fields: [saleId], references: [id])
  commissioningNotes String?
  commissionDate     DateTime? @db.Date
  updatedAt          DateTime @updatedAt
}

// postInstallDetails — can recur (multiple issues over time), so 1:n.
model PostInstallIssue {
  id           String   @id @default(uuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id])
  issueLogDate DateTime? @db.Date
  issueNotes   String?
  solution     String?
  handledById  String?                               // "handledBy" -> user
  handledBy    User?    @relation("IssueHandler", fields: [handledById], references: [id])
  createdAt    DateTime @default(now())

  @@index([saleId])
}

// ----- Sale change log (general: any field change, old->new, who, when) -----
// Sibling of LeadStateLog, written via a SaleHistoryService choke point.
model SaleLog {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  section   String                                   // e.g. "systemDetails", "statusDetails.installStatus"
  field     String                                   // which field changed
  oldValue  String?
  newValue  String?
  changedBy String                                   // userId
  changedAt DateTime @default(now())

  @@index([saleId])
  @@index([changedAt])
}

model SaleStageHistory {
  id        String      @id @default(uuid())
  saleId    String
  sale      Sale        @relation(fields: [saleId], references: [id])
  fromStage SaleStatus?
  toStage   SaleStatus
  changedBy String
  changedAt DateTime    @default(now())

  @@index([saleId])
}

// ============================================================================
//  INSTALLATION & CUSTOMER (Tier-3 narrow roles)
//  Installation == the sale's "installDetails" block (installer, date, notes).
// ============================================================================

model Installation {
  id              String             @id @default(uuid())
  saleId          String             @unique
  sale            Sale               @relation(fields: [saleId], references: [id])

  installerId     String?
  installer       User?              @relation("Installer", fields: [installerId], references: [id])

  status          InstallationStatus @default(SCHEDULED)
  installDate     DateTime?          @db.Date          // "installDate"
  scheduledAt     DateTime?
  completedAt     DateTime?
  notes           String?
  postInstallNotes String?                             // "postInstallNotes"
  sortOrder       Int?                                 // manual drag-and-drop row order (null = default sort)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([installerId])
  @@index([status])
}

enum InstallationStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

// ============================================================================
//  CUSTOMER — self-service login linked to a single Sale (Customer dashboard).
//  Customer identity/contact details are read via the sale's lead (flattened);
//  this model only ties a User login to the sale they own.
// ============================================================================

model Customer {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  saleId    String   @unique
  sale      Sale     @relation(fields: [saleId], references: [id])
  createdAt DateTime @default(now())
}

// ============================================================================
//  ACTIVITY, DISPOSITION HISTORY & AUDIT LOG
// ============================================================================

model Activity {
  id         String   @id @default(uuid())
  type       String                                 // call | email | note | task
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  content    String?
  createdAt  DateTime @default(now())

  @@index([leadId])
  @@index([userId])
}

// LeadStateLog — the lead's STATUS TIMELINE (machine-oriented, structured).
// Point-in-time snapshot written on every state change. IDs and statuses are
// stored AS THEY WERE at changedAt (immutable history) — deliberately
// denormalized so reassignments don't rewrite the past. Feeds analytics
// (time-in-stage, funnels) and the future AI. Distinct from Activity (human
// actions) and AuditLog (system-wide security trail).
model LeadStateLog {
  id          String            @id @default(uuid())
  leadId      String
  lead        Lead              @relation(fields: [leadId], references: [id])

  stage       LeadStage                              // stage at this moment
  leadGenId   String?                                // lead-gen attached at this moment
  consultantId String?                               // consultant attached at this moment
  outcome     LeadOutcome?                           // lead-gen result at this moment
  disposition SalesDisposition?                      // consultant result at this moment

  changedBy   String                                 // userId who triggered the change
  changedAt   DateTime          @default(now())      // log timestamp

  @@index([leadId])
  @@index([changedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String                                   // LEAD_CONVERTED, BOOKING_CREATED, ...
  entity    String
  entityId  String
  source    String   @default("app")                 // app | google_sheets | voice (future)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
//  STORAGE (Phase 3) — document metadata in Postgres, blobs in Cloudflare R2.
//  Uploads go client -> R2 via presigned URL; only the metadata row lives here.
// ============================================================================

model Document {
  id          String   @id @default(uuid())
  // What this document is attached to (loose polymorphic link kept simple).
  entity      String                                   // "Sale" | "Lead"
  entityId    String
  key         String   @unique                         // R2 object key
  fileName    String
  contentType String?
  sizeBytes   Int?
  uploadedById String
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([uploadedById])
}

// ============================================================================
//  BLOOME LEADS — raw appointment-setter rows imported from the Bloome
//  "ASTRA - MASTER BLASTER" Google Sheet (one row per dialled lead).
//
//  Deliberately separate from `Lead`: these are unowned, free-form setter
//  records (string outcomes like "Hot Call Back", bill-spend bands, Bloome
//  agents who are not CRM users). Promoting one into the managed pipeline
//  creates a `Lead` (customer details flattened on); this table stays the import truth.
//  Dedupe key: (sourceTab, rowNum) — the sheet tab + 1-based sheet row.
// ============================================================================

model BloomeLead {
  id             String    @id @default(uuid())
  region         String                              // "ACT" | "TAS" | ...
  sourceTab      String                              // e.g. "ACT:Live"
  rowNum         Int                                 // 1-based row in the source tab
  wc             String?                             // sheet working-copy flag column
  timestamp      DateTime?                           // form submission time (null if unparseable)
  firstName      String?
  lastName       String?
  mobile         String?
  email          String?
  address        String?
  postcode       String?
  suburb         String?
  billSpend      String?                             // band as recorded ("$251-$500", ...)
  code           String?                             // campaign code ("ACT-1", ...)
  agent          String?                             // Bloome setter (Daniel, Ambrose, ...)
  dials          Int       @default(0)
  outcome        String?                             // raw label ("Appointment", "Hot Call Back", ...)
  company        String?                             // assigned company ("Astra" default | "DCsolar")
  notes          String?
  lastCalled     String?                             // free-form date text from the sheet
  appDate        String?                             // appointment date as recorded (dd/mm/yyyy)
  appTime        String?                             // appointment time as recorded (24h)
  existingSystem String?

  // Blacklist enforcement (Leads -> Blacklist Leads). Set true by the sweep
  // when this Bloome lead matches a BlacklistEntry; filtered out of the tab.
  blacklisted      Boolean   @default(false)
  blacklistedAt    DateTime?
  blacklistEntryId String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([sourceTab, rowNum])
  @@index([region])
  @@index([outcome])
  @@index([agent])
  @@index([company])
  @@index([mobile])
  @@index([timestamp])
}

// ============================================================================
//  SCHEDULING — consultant availability + the Leads Schedule grid.
//  Migrated from the legacy web database (apps/web prisma) so the platform
//  runs on a single database. Date columns are DATE; all reads/writes must
//  use UTC-midnight Dates (see the web lib's DB date boundary note).
// ============================================================================

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  HOLIDAY
}

model AvailabilitySlot {
  id           String             @id @default(uuid())
  consultantId String                              // User.id of the consultant
  consultant   User               @relation("ConsultantAvailability", fields: [consultantId], references: [id], onDelete: Cascade)
  date         DateTime           @db.Date
  hour         Int                                 // 8..19 — start hour of the 1-hour slot
  status       AvailabilityStatus
  note         String?
  createdById  String?                             // user who made the change (audit)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([consultantId, date, hour])
  @@index([date])
  @@index([consultantId, date])
}

model AvailabilitySubmission {
  id             String   @id @default(uuid())
  consultantId   String
  consultant     User     @relation("ConsultantAvailabilitySubmissions", fields: [consultantId], references: [id], onDelete: Cascade)
  consultantName String                            // snapshot at submission time
  weekStart      DateTime @db.Date
  weekEnd        DateTime @db.Date
  holidayDays    String[]                          // ISO dates fully marked Holiday
  slotsCount     Int      @default(0)
  submitted      Boolean  @default(true)
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  updatedById    String?
  updatedByName  String?

  @@unique([consultantId, weekStart])
  @@index([weekStart])
  @@index([consultantId])
}

// One cell of the Leads Schedule grid. Contact details are denormalised
// snapshots (imported from the legacy database); `leadId` optionally links a
// modern pipeline Lead. Distinct from `Booking`, which is the pipeline's
// outcome-triggered record.
model Appointment {
  id               String    @id @default(uuid())
  leadId           String?
  lead             Lead?     @relation("LeadScheduleAppointments", fields: [leadId], references: [id], onDelete: SetNull)
  consultantId     String
  consultant       User      @relation("ConsultantScheduleAppointments", fields: [consultantId], references: [id], onDelete: Cascade)

  date             DateTime  @db.Date
  hour             Int                              // 8..19
  minute           Int       @default(0)            // 0 or 30
  durationMinutes  Int       @default(60)

  disposition      String?
  bookedByUserId   String?
  bookedByName     String?
  source           String?                          // Brighte | Referral | Website | Bloome | ...
  company          String?                          // Astra | DC ELEC | ...
  bills            String?
  notes            String?

  // Contact snapshot
  customerName     String?
  firstName        String?
  lastName         String?
  phone            String?
  email            String?
  address          String?
  suburb           String?
  state            String?
  postcode         String?

  // Reschedule audit (most recent move only)
  originalDate     DateTime? @db.Date
  originalHour     Int?
  originalMinute   Int?
  rescheduleReason String?
  rescheduledAt    DateTime?

  isAdditional     Boolean   @default(false)
  cancelPending    String?                          // 'cancel' | 'dnq' | 'not_interested'
  cancelPendingAt  DateTime?

  // Blacklist enforcement (Leads -> Blacklist Leads). Set true by the sweep
  // when this appointment matches a BlacklistEntry; filtered out of the
  // Leads Schedule grid.
  blacklisted      Boolean   @default(false)
  blacklistedAt    DateTime?
  blacklistEntryId String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([date])
  @@index([consultantId, date])
  @@index([leadId])
}

// ============================================================================
//  BLACKLIST LEADS (Leads -> Blacklist Leads)
//
//  Ported from the astrasolar-app Firebase node `/blacklistLeads`. An entry
//  blocks a person from appearing in Bloome / No Answers / Leads Schedule: a
//  sweep flags any record matching the entry on >=2 normalised fields
//  (phone / email / name / address) and writes a removal-log row.
// ============================================================================

model BlacklistEntry {
  id        String  @id @default(uuid())
  firstName String?
  lastName  String?
  phone     String?
  email     String?
  address   String?

  addedById   String?
  addedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  removals  BlacklistRemovalLog[]

  @@index([phone])
  @@index([email])
}

model BlacklistRemovalLog {
  id         String   @id @default(uuid())
  detectedAt DateTime @default(now())
  removedAt  DateTime @default(now())
  source     String                               // "Bloome" | "No Answers" | "Leads Schedule"

  // Snapshot of the removed lead (so the log survives the source record).
  matchedFirstName String?
  matchedLastName  String?
  matchedPhone     String?
  matchedEmail     String?
  matchedAddress   String?
  matchedOn        String                          // "phone, email" — the fields that aligned

  entryId      String?
  entry        BlacklistEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  removedById   String?
  removedByName String?

  @@index([detectedAt])
  @@index([entryId])
}

// ============================================================================
//  TASK BOARDS (Trello-style "Task Overview" tab — one shared board per
//  dashboard: leads / sales / sales-manager / operations-manager / admin)
// ============================================================================

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model TaskList {
  id           String     @id @default(uuid())
  dashboardKey String                              // board key = dashboard ("sales", "leads", ...)
  name         String
  position     Int                                 // 0-based column order within the board
  tasks        TaskCard[]
  createdById  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([dashboardKey, position])
}

model TaskCard {
  id          String       @id @default(uuid())
  listId      String
  list        TaskList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @db.Date
  position    Int                                  // 0-based order within the list

  // Completion state (drives the "Completed tasks" toggle in the Display menu).
  completed   Boolean      @default(false)
  completedAt DateTime?

  // Task-detail fields (Todoist-style detail panel).
  deadline    DateTime?    @db.Date              // hard deadline, distinct from the scheduled dueDate
  location    String?
  labels      String[]     @default([])
  reminders   DateTime[]   @default([])          // scheduled reminder datetimes

  // Sub-tasks: a card may nest under a parent card (same list/board). Top-level
  // board cards have parentId = null; sub-tasks are excluded from board columns.
  parentId    String?
  parent      TaskCard?    @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  children    TaskCard[]   @relation("TaskSubtasks")

  comments    TaskComment[]

  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User         @relation("TaskCreator", fields: [createdById], references: [id])

  // Last nudge sent to the assignee (in-app indicator; cleared when the
  // assignee touches the card). Rate-limited to one per task per hour.
  nudgedAt    DateTime?
  nudgedById  String?
  nudgedBy    User?        @relation("TaskNudger", fields: [nudgedById], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([listId, position])
  @@index([assigneeId])
  @@index([completed])
  @@index([parentId])
}

// A comment on a task card (detail-panel discussion thread).
model TaskComment {
  id        String   @id @default(uuid())
  cardId    String
  card      TaskCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TaskCommentAuthor", fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([cardId])
}

// ============================================================================
// Financials dashboard (ported from v1 CEO Financials widget)
// ============================================================================

// Extra weekly operating costs entered by finance/CEO on the Financials widget.
// The fixed BASELINE weekly cost lives in code (financials.constants.ts) — these
// rows are the manual "Extra Weekly Costs" stacked on top. Entries labelled
// "bloome" / "bloome leads" are treated as variable lead-acquisition spend and
// excluded from fixed costs (v1 parity — avoids double-counting against the
// per-lead Bloome spend computed from lead counts).
model OperatingCost {
  id          String   @id @default(uuid())
  weekStart   DateTime @db.Date                     // Monday of the week the cost applies to
  label       String
  amount      Decimal  @db.Decimal(12, 2)
  createdById String?                               // User.id (no FK — audit-style reference)
  createdAt   DateTime @default(now())

  @@index([weekStart])
}

// A request for finance to price custom (non-catalogue) products on a sale so
// commissions/oversell can be computed. v1: Firebase `pendingRrpRequests`.
model RrpRequest {
  id            String           @id @default(uuid())
  saleId        String
  sale          Sale             @relation(fields: [saleId], references: [id])
  status        RrpRequestStatus @default(PENDING)
  // [{ "type": "Battery", "product": "Tesla PW3", "rrp": 12000? }] — rrp filled on completion
  items         Json
  requestedById String?                             // User.id of the consultant
  completedById String?                             // User.id of finance member who priced it
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([saleId])
}

enum RrpRequestStatus {
  PENDING
  COMPLETED
  DISMISSED
}

// ============================================================================
//  NOTIFICATIONS — in-app notification centre. A row is one message addressed
//  to one user (e.g. the lead-gen who booked a lead is told it now needs
//  rebooking after the consultant marked it RESCHEDULE). `type` is a stable
//  machine key; `entityType`/`entityId` deep-link the recipient to the record
//  they need to act on (e.g. an Appointment to rebook).
// ============================================================================
model Notification {
  id         String    @id @default(uuid())
  userId     String                                  // recipient
  user       User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  type       String                                  // e.g. LEAD_NEEDS_REBOOKING
  title      String
  body       String?
  entityType String?                                 // e.g. Appointment
  entityId   String?                                 // e.g. Appointment.id
  data       Json?                                   // optional structured payload for the UI
  actorId    String?                                 // User.id who triggered it (no FK — audit-style)

  readAt     DateTime?                               // null = unread
  createdAt  DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ============================================================================
//  SOLAR PRODUCT CATALOGUE
//  Dedicated catalogue for solar (panel) products. Pricing is EFFECTIVE-DATED:
//  `effectiveDate` is the date the CURRENT solarRrp / solarCommission took
//  effect. The row always carries the latest values; every change is mirrored
//  into SolarProductLog (same transaction) via a history choke point, where
//  `effectiveDate` is MANDATORY so price/commission can be reconstructed as-of
//  any date. `status` controls visibility: DISCONTINUED hides the product from
//  new-sale pickers, ARCHIVED is a soft-delete. Rows are never hard-deleted
//  while referenced by historical sales.
// ============================================================================
model SolarProduct {
  id              String             @id @default(uuid())  // productID
  productName     String                                   // display name
  brand           String?                                  // e.g. Jinko, Trina, REC
  panelModel      String?                                  // e.g. JKM475N-48HL4M-DV [AU]
  panelWatt       Int?                                     // per-panel wattage (W)
  systemSize      Decimal?           @db.Decimal(10, 3)    // full system size (kW, e.g. 9.975)
  solarStc        Decimal?           @db.Decimal(12, 2)    // rebate STC value
  numOfPanels     Int?                                     // derived: round(systemSize * 1000 / panelWatt)

  states          String[]           @default([])          // AU states it applies to (empty = all)
  status          SolarProductStatus @default(ACTIVE)

  // Commercials — current values; `effectiveDate` is when these took effect.
  solarRrp        Decimal?           @db.Decimal(12, 2)
  solarCommission Decimal?           @db.Decimal(12, 2)
  profit          Decimal?           @db.Decimal(12, 2)
  effectiveDate   DateTime?          @db.Date              // pricing effective-from

  notes           String?

  // Change history (effectiveDate is required on every entry — see model below)
  logs            SolarProductLog[]

  sortOrder       Int?                                     // manual drag-and-drop row order (null = default sort)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([brand])
  @@index([effectiveDate])
}

enum SolarProductStatus {
  ACTIVE
  DISCONTINUED   // hidden from new sales, kept for history
  ARCHIVED       // soft-delete
}

// Solar product change log — one row per field change (old -> new), who changed
// it, and the date the change BECOMES EFFECTIVE. `effectiveDate` is REQUIRED so
// the catalogue's price/commission history can be replayed as-of any date.
// Written through a history choke point (sibling of ProductLog / SaleLog).
model SolarProductLog {
  id            String       @id @default(uuid())
  productId     String
  product       SolarProduct @relation(fields: [productId], references: [id])

  field         String                                     // which field changed
  oldValue      String?
  newValue      String?

  effectiveDate DateTime     @db.Date                      // REQUIRED — when this change takes effect
  changedBy     String                                     // userId (or "import")
  changedAt     DateTime     @default(now())               // when the log row was written

  @@index([productId])
  @@index([effectiveDate])
  @@index([changedAt])
}

// ============================================================================
//  INVERTER CATALOGUE
//  Dedicated catalogue for inverter products (sibling of SolarProduct). Every
//  change is mirrored into InverterProductLog (same transaction) via a history
//  choke point, where `effectiveDate` is MANDATORY. `status` controls
//  visibility: DISCONTINUED hides from new-sale pickers, ARCHIVED is a
//  soft-delete. Rows are never hard-deleted while referenced by historical sales.
// ============================================================================
model InverterProduct {
  id            String              @id @default(uuid())    // productID
  productName   String                                      // display name
  brand         String?                                     // e.g. GoodWe, Sungrow, Fronius
  inverterModel String?                                     // e.g. GW9.999KEHA-G20
  type          String?                                     // e.g. String | Hybrid | Microinverter
  phase         Int?                                        // 1 or 3 (null = both)
  systemSize    Decimal?            @db.Decimal(10, 3)       // rated system size (kW)
  maxPVArray    Decimal?            @db.Decimal(10, 3)       // max PV array the inverter supports (kW)
  mppt          Int?                                        // number of MPPT trackers
  strings       Int?                                        // number of PV strings
  notes         String?

  states        String[]            @default([])            // AU states it applies to (empty = all)
  status        InverterStatus      @default(ACTIVE)

  // Change history (effectiveDate is required on every entry — see model below)
  logs          InverterProductLog[]

  // Batteries that are allowed to pair with this inverter (explicit allow-list)
  compatibleBatteries BatteryInverterCompat[]

  sortOrder     Int?                                        // manual drag-and-drop row order (null = default sort)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status])
  @@index([type])
  @@index([phase])
  @@index([brand])
}

enum InverterStatus {
  ACTIVE
  DISCONTINUED   // hidden from new sales, kept for history
  ARCHIVED       // soft-delete
}

// Inverter change log — one row per field change (old -> new), who changed it,
// and the date the change BECOMES EFFECTIVE. `effectiveDate` is REQUIRED so the
// catalogue's history can be replayed as-of any date. Sibling of SolarProductLog.
model InverterProductLog {
  id            String          @id @default(uuid())
  productId     String
  product       InverterProduct @relation(fields: [productId], references: [id])

  field         String                                      // which field changed
  oldValue      String?
  newValue      String?

  effectiveDate DateTime        @db.Date                    // REQUIRED — when this change takes effect
  changedBy     String                                      // userId (or "import")
  changedAt     DateTime        @default(now())             // when the log row was written

  @@index([productId])
  @@index([effectiveDate])
  @@index([changedAt])
}

// ============================================================================
//  EXTRAS CATALOGUE
//  Dedicated catalogue for add-on line items (sibling of SolarProduct /
//  InverterProduct). `unitPrice` is the current price; every change is mirrored
//  into ExtraProductLog (same transaction) via a history choke point, where
//  `effectiveDate` is MANDATORY so pricing can be replayed as-of any date.
// ============================================================================
model ExtraProduct {
  id          String           @id @default(uuid())         // productID
  itemName    String                                        // display name
  category    String?                                       // grouping (e.g. "Electrical", "Mounting", "Misc")
  unit        String?                                       // free-form size/spec (e.g. "5m", "2.5kW", "1")
  unitPrice   Decimal?         @db.Decimal(12, 2)
  notes       String?

  // Change history (effectiveDate is required on every entry — see model below)
  logs        ExtraProductLog[]

  sortOrder   Int?                                          // manual drag-and-drop row order (null = default sort)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// Extras change log — one row per field change (old -> new), who changed it, and
// the date the change BECOMES EFFECTIVE. `effectiveDate` is REQUIRED so the
// catalogue's price history can be replayed as-of any date. Sibling of the
// other catalogue logs.
model ExtraProductLog {
  id            String       @id @default(uuid())
  productId     String
  product       ExtraProduct @relation(fields: [productId], references: [id])

  field         String                                      // which field changed
  oldValue      String?
  newValue      String?

  effectiveDate DateTime     @db.Date                       // REQUIRED — when this change takes effect
  changedBy     String                                      // userId (or "import")
  changedAt     DateTime     @default(now())                // when the log row was written

  @@index([productId])
  @@index([effectiveDate])
  @@index([changedAt])
}

// ============================================================================
//  BATTERY CATALOGUE
//  Dedicated catalogue for battery products (sibling of SolarProduct). Pricing
//  is EFFECTIVE-DATED: `effectiveDate` is the date the CURRENT batteryRrp /
//  batteryCommission took effect. Every change is mirrored into
//  BatteryProductLog (same transaction) via a history choke point, where
//  `effectiveDate` is MANDATORY. `status` controls visibility: DISCONTINUED
//  hides from new-sale pickers, ARCHIVED is a soft-delete.
// ============================================================================
model BatteryProduct {
  id               String             @id @default(uuid())  // productID
  productName      String                                   // display name
  brand            String?                                  // e.g. GoodWe, Fox ESS, Tesla
  batteryModel     String?                                  // e.g. GW8.3-BAT-D-G20
  batterySize      Decimal?           @db.Decimal(10, 2)    // usable capacity (kWh)
  modules          Int?                                     // number of battery modules
  batteryStc       Decimal?           @db.Decimal(12, 2)    // rebate STC value
  phase            Int?                                      // 1 or 3 (null = both)

  states           String[]           @default([])          // AU states it applies to (empty = all)
  status           BatteryStatus      @default(ACTIVE)

  // Commercials — current values; `effectiveDate` is when these took effect.
  // NOTE: batteryRrp is CONTEXT-DEPENDENT (differs battery-only vs solar+battery)
  // and lives in BatteryContextPrice, not here. The fields below do NOT vary by
  // sale context.
  grossPrice       Decimal?           @db.Decimal(12, 2)
  batteryCommission Decimal?          @db.Decimal(12, 2)
  profit           Decimal?           @db.Decimal(12, 2)
  effectiveDate    DateTime?          @db.Date              // pricing effective-from

  notes            String?

  // Change history (effectiveDate is required on every entry — see model below)
  logs             BatteryProductLog[]

  // Inverters this battery is allowed to pair with (explicit allow-list)
  compatibleInverters BatteryInverterCompat[]

  // Per-context RRP (battery-only vs solar+battery) — see BatteryContextPrice
  contextPrices    BatteryContextPrice[]

  sortOrder        Int?                                     // manual drag-and-drop row order (null = default sort)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
  @@index([brand])
  @@index([effectiveDate])
}

enum BatteryStatus {
  ACTIVE
  DISCONTINUED   // hidden from new sales, kept for history
  ARCHIVED       // soft-delete
}

// Battery change log — one row per field change (old -> new), who changed it,
// and the date the change BECOMES EFFECTIVE. `effectiveDate` is REQUIRED so the
// catalogue's price/commission history can be replayed as-of any date. Sibling
// of SolarProductLog.
model BatteryProductLog {
  id            String         @id @default(uuid())
  productId     String
  product       BatteryProduct @relation(fields: [productId], references: [id])

  field         String                                      // which field changed
  oldValue      String?
  newValue      String?

  effectiveDate DateTime       @db.Date                     // REQUIRED — when this change takes effect
  changedBy     String                                      // userId (or "import")
  changedAt     DateTime       @default(now())              // when the log row was written

  @@index([productId])
  @@index([effectiveDate])
  @@index([changedAt])
}

// ============================================================================
//  BATTERY <-> INVERTER COMPATIBILITY
//  Explicit allow-list: a battery may be paired with an inverter ONLY if a row
//  exists here. Many-to-many (one inverter supports many batteries; one battery
//  fits many inverters). Pricing is NOT stored here — it lives on BatteryProduct
//  (price is fixed per battery, independent of the inverter). Toggle `isActive`
//  to disable a pairing without deleting it (keeps historical sales resolvable).
//
//  Query "batteries that work with inverter X":
//    prisma.batteryInverterCompat.findMany({
//      where: { inverterId: X, isActive: true }, include: { battery: true }
//    })
// ============================================================================
model BatteryInverterCompat {
  id          String          @id @default(uuid())
  inverterId  String
  inverter    InverterProduct @relation(fields: [inverterId], references: [id])
  batteryId   String
  battery     BatteryProduct  @relation(fields: [batteryId], references: [id])

  isActive    Boolean         @default(true)                // disable a pairing without deleting it
  notes       String?                                       // optional note (e.g. firmware caveat)

  // Per-context pricing for THIS combo (gross + RRP differ standalone vs with-solar,
  // and vary by inverter — so price lives on the combo, not on BatteryProduct).
  comboPrices BatteryComboContextPrice[]

  createdById String?                                       // User.id who added the pairing (audit)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([inverterId, batteryId])                         // one row per pair (no duplicates)
  @@index([inverterId])
  @@index([batteryId])
}

// ============================================================================
//  BATTERY CONTEXT PRICING
//  A battery's RRP depends on HOW it is sold: standalone (BATTERY_ONLY) vs
//  bundled with solar (SOLAR_BATTERY). One row per (battery, context) holds the
//  RRP for that context, effective-dated, with its own change log (effectiveDate
//  MANDATORY). Only the RRP varies by context — commission/profit/grossPrice/STC
//  stay on BatteryProduct. The sale layer reads the row matching the sale's
//  context to price the battery.
// ============================================================================
enum BatteryPriceContext {
  BATTERY_ONLY    // sold standalone
  SOLAR_BATTERY   // sold bundled with solar
}

model BatteryContextPrice {
  id            String         @id @default(uuid())
  batteryId     String
  battery       BatteryProduct @relation(fields: [batteryId], references: [id])

  context       BatteryPriceContext
  batteryRrp    Decimal?       @db.Decimal(12, 2)           // customer price for THIS context
  effectiveDate DateTime?      @db.Date                     // when this RRP took effect

  logs          BatteryContextPriceLog[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([batteryId, context])                            // at most one price row per context
  @@index([batteryId])
}

// Change log for context pricing (sibling of the catalogue logs). effectiveDate
// REQUIRED so the per-context RRP history can be replayed as-of any date.
model BatteryContextPriceLog {
  id             String              @id @default(uuid())
  contextPriceId String
  contextPrice   BatteryContextPrice @relation(fields: [contextPriceId], references: [id])

  field          String                                     // which field changed (e.g. "batteryRrp")
  oldValue       String?
  newValue       String?

  effectiveDate  DateTime            @db.Date               // REQUIRED — when this change takes effect
  changedBy      String                                     // userId (or "import")
  changedAt      DateTime            @default(now())        // when the log row was written

  @@index([contextPriceId])
  @@index([effectiveDate])
  @@index([changedAt])
}

// ============================================================================
//  BATTERY COMBO (INVERTER + BATTERY) CONTEXT PRICING
//  gross price AND customer RRP depend on the SPECIFIC inverter the battery is
//  paired with AND on HOW it is sold (standalone vs bundled with solar). So the
//  priced unit is the inverter+battery COMBO (a BatteryInverterCompat row), with
//  one price row per context. Battery-intrinsic figures (modules, size, STC,
//  profit, commission) stay on BatteryProduct. Effective-dated with its own log.
//  The sale layer reads the row matching (combo, sale context) to price it.
// ============================================================================
model BatteryComboContextPrice {
  id            String                @id @default(uuid())
  compatId      String
  compat        BatteryInverterCompat @relation(fields: [compatId], references: [id], onDelete: Cascade)

  context       BatteryPriceContext                              // BATTERY_ONLY = standalone, SOLAR_BATTERY = with solar
  grossPrice    Decimal?              @db.Decimal(12, 2)         // internal gross cost for THIS combo + context
  batteryRrp    Decimal?              @db.Decimal(12, 2)         // customer price for THIS combo + context
  effectiveDate DateTime?             @db.Date                   // when these prices took effect

  logs          BatteryComboContextPriceLog[]

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([compatId, context])                                 // one price row per combo per context
  @@index([compatId])
}

// Change log for combo pricing (effectiveDate REQUIRED so combo price history
// can be replayed as-of any date). Sibling of the other pricing logs.
model BatteryComboContextPriceLog {
  id             String                   @id @default(uuid())
  comboPriceId   String
  comboPrice     BatteryComboContextPrice @relation(fields: [comboPriceId], references: [id])

  field          String                                          // which field changed (grossPrice | batteryRrp)
  oldValue       String?
  newValue       String?

  effectiveDate  DateTime                 @db.Date               // REQUIRED — when this change takes effect
  changedBy      String                                          // userId (or "import")
  changedAt      DateTime                 @default(now())        // when the log row was written

  @@index([comboPriceId])
  @@index([effectiveDate])
  @@index([changedAt])
}

// ============================================================================
//  NOVA — the in-house AI assistant (Claude-powered)
//
//    Ported from the legacy Firebase app (astrasolar-app). Where Nova used to
//    read/write Firebase RTDB nodes (novaUsage, novaKnowledge, AI_KB, [LEARN::]
//    memory), she now uses these Postgres tables. Conversations + messages give
//    her persistent history; KnowledgeEntry is the curated KB; Memory is the
//    self-taught fact store ("newer overrides older"); UsageLog is the cost +
//    audit trail. Embeddings (pgvector) are a later raw migration — keyword
//    search is the default, matching the rest of the schema's convention.
// ============================================================================

model NovaConversation {
  id        String        @id @default(uuid())
  userId    String                                  // owner (AuthUser.id)
  title     String?                                 // auto-summarised from first message
  archived  Boolean       @default(false)
  messages  NovaMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@index([updatedAt])
}

model NovaMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   NovaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           String                              // 'user' | 'assistant'
  content        String                              // visible text
  toolCalls      Json?                               // tool_use / tool_result trace for this turn
  model          String?
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

// The AI_KB port — curated question/answer knowledge, keyword-searched and
// injected into Nova's prompt. Managed via the Knowledge Brain admin UI.
model NovaKnowledgeEntry {
  id         String    @id @default(uuid())
  category   String
  question   String
  answer     String
  tags       String[]  @default([])
  authority  String?
  source     String?
  sourceDate DateTime?
  status     String    @default("active")           // active | deprecated
  createdBy  String?                                 // userId or 'system' (imported)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([category])
}

// The [LEARN::category::fact] port — Nova's permanent self-taught memory.
// Newer facts override older ones (see supersedes).
model NovaMemory {
  id         String   @id @default(uuid())
  category   String                                  // sales_advice, commissions, pronunciation, ...
  fact       String
  createdBy  String?                                 // who taught it (userId) or 'system'
  supersedes String?                                 // id of the memory this overrides
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([category])
  @@index([active])
}

// Cost + audit trail (the novaUsage / novaToolUsage port). One row per chat
// request. Readable by finance/CEO/admin for cost tracking.
model NovaUsageLog {
  id           String   @id @default(uuid())
  userId       String
  model        String?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  toolCalls    Int      @default(0)
  status       String                                // ok | denied_role | rate_limited | upstream_error | fetch_failed
  detail       String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Runtime-editable Nova settings (the AI_CONFIG port). A small key/value store
// so a CEO/Super Admin can manage the ElevenLabs + D-ID credentials from the UI
// instead of env vars. DB value (when set) overrides the matching env var. The
// Anthropic key is intentionally NOT stored here — it stays env-only.
model NovaSetting {
  key       String   @id              // e.g. elevenlabs_api_key, did_agent_id, did_client_key
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ============================================================================
//  LEAD CHECKLIST — per-lead system-recommendation capture + AI result
// ----------------------------------------------------------------------------
// Filled by the assigned consultant before an appointment. On submit, the
// captured payload is sent to Nova (NovaRecommendationService), which returns
// 5 quote-ready system packages with one marked "Most Recommended". The
// captured fields stay queryable columns; the day/usage split, prior-system
// block, brand preferences and the AI result are stored as JSON. DRAFT = saved
// with no AI call; COMPLETED = an AI result is attached.
// ============================================================================

enum ChecklistStatus {
  DRAFT
  COMPLETED
}

model LeadChecklist {
  id            String          @id @default(uuid())
  leadId        String          @unique                 // 1 lead -> at most 1 checklist
  lead          Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status        ChecklistStatus @default(DRAFT)

  // ── Group 1 — Lead & site ────────────────────────────────────────────────
  state         String?                                  // NSW | ACT | TAS (drives finance + TAS permit logic)
  nmi           String?                                  // National Meter Identifier (10–11 chars)
  roofType      String?                                  // tile | tin-colorbond | klip-lok | decramastic | flat-membrane
  storeys       Int?
  orientation   String?                                  // roof orientation / aspect
  shadingNotes  String?
  phase         String?                                  // single | three
  switchboard   String?                                  // age / condition note

  // ── Group 2 — Energy profile ─────────────────────────────────────────────
  spendAmount   Decimal?        @db.Decimal(12, 2)       // current electricity spend
  spendPeriod   String?                                  // quarter | year
  usageSplit    Json?                                    // { day: %, night: % }
  drivers       String[]        @default([])             // customer drivers (multi-select keys)
  budgetPosture String?                                  // cash | finance | show_both

  // ── Group 3 — System category ────────────────────────────────────────────
  category      String?                                  // new | replacement | additional | both
  priorSystem   Json?                                    // conditional block when category != new

  // ── Group 4 — Constraints / preferences ──────────────────────────────────
  preferredBrands String[]      @default([])
  excludedBrands  String[]      @default([])
  batteryPref   String?                                  // yes | no | let_ai_decide
  evChargerPref String?                                  // yes | no | let_ai_decide
  budgetCeiling Decimal?        @db.Decimal(12, 2)

  // ── AI result (the 5 quote-ready packages) ───────────────────────────────
  result              Json?                              // full SystemRecommendationResult contract
  recommendedOptionId String?                            // the option flagged "Most Recommended"
  selectedOptionId    String?                            // the option the consultant chose to use
  generatedAt         DateTime?

  createdById   String
  createdBy     User            @relation("ChecklistCreatedBy", fields: [createdById], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([createdById])
}

// ============================================================================
//  COMMUNICATIONS — outbound/inbound SMS (ClickSend) and calls (Aircall).
//
//  Both are kept as first-class, queryable rows (not just Activity entries) so
//  delivery status, recordings and per-lead history can be reported on. They
//  use a loose link to the lead/customer (`leadId`, no hard FK) — the same
//  polymorphic pattern as Document/AuditLog — so a message/call can reference a
//  record without forcing a back-relation onto the (large) Lead model. Every
//  send/event also writes an Activity (human feed) + AuditLog (security trail).
// ============================================================================

// SmsMessage — one row per ClickSend SMS. Outbound rows are created at send
// time (status QUEUED/SENT), then advanced by the delivery-receipt webhook.
model SmsMessage {
  id          String      @id @default(uuid())

  direction   SmsDirection @default(OUTBOUND)
  status      SmsStatus    @default(QUEUED)

  toNumber    String                                   // E.164 recipient ("+61…")
  fromNumber  String?                                  // sender ID / number used
  body        String

  // Loose links (no FK — mirrors Document). leadId set when texting a lead.
  leadId      String?
  // The CRM user who triggered the send (null for inbound).
  sentById    String?

  brand       Company?                                 // ASTRA | DC — which sender profile
  senderId    String?                                  // ClickSend alphanumeric sender ID used

  // ClickSend bookkeeping.
  providerMessageId String?                            // ClickSend message_id
  messagePrice      String?                            // cost reported by ClickSend
  errorCode         String?                            // ClickSend error/status code on failure
  errorText         String?

  segments    Int?                                     // number of SMS parts

  sentAt      DateTime?                                // when ClickSend accepted it
  deliveredAt DateTime?                                // from the delivery receipt
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([leadId])
  @@index([sentById])
  @@index([status])
  @@index([providerMessageId])
  @@index([toNumber])
}

enum SmsDirection {
  OUTBOUND
  INBOUND
}

enum SmsStatus {
  QUEUED        // created locally, not yet accepted by ClickSend
  SENT          // accepted by ClickSend (SUCCESS on submit)
  DELIVERED     // delivery receipt: delivered
  FAILED        // submit failed or delivery receipt: undelivered/failed
  RECEIVED      // inbound message
}

// CallLog — one row per Aircall call, created/updated from webhook events.
// Deduped on the Aircall call id (`providerCallId`).
model CallLog {
  id            String        @id @default(uuid())

  direction     CallDirection
  status        CallStatus    @default(INITIAL)

  fromNumber    String?
  toNumber      String?

  // Loose link to the matched lead (by phone) — no FK (mirrors Document).
  leadId        String?
  // The CRM user mapped from the Aircall agent (by email), if matched.
  agentId       String?

  // Aircall bookkeeping.
  providerCallId String       @unique                  // Aircall call.id
  aircallUserEmail String?                             // agent email from Aircall
  aircallNumberId  String?                             // Aircall line/number id

  durationSeconds Int?
  recordingUrl    String?                              // Aircall recording (if available)
  voicemailUrl    String?

  startedAt     DateTime?
  answeredAt    DateTime?
  endedAt       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([leadId])
  @@index([agentId])
  @@index([status])
  @@index([direction])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  INITIAL       // call.created
  RINGING
  ANSWERED      // call.answered
  ENDED         // call.ended / hungup
  MISSED        // ended without answer
  VOICEMAIL
  FAILED
}
