# PostgreSQL (Neon / Railway-managed). pgvector enabled later for AI phase.
DATABASE_URL="postgresql://user:password@localhost:5432/astra_crm?schema=public"

# JWT (self-managed auth)
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"

# Cookies
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"

# CORS — the Netlify web origin
WEB_ORIGIN="http://localhost:3000"

# Server
PORT="4000"

# Cloudflare R2 (Phase 3 storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="astra-crm"
R2_PUBLIC_BASE_URL=""

# Google Sheets intake (Phase 2.5)
GOOGLE_SHEETS_ID=""
GOOGLE_SERVICE_ACCOUNT_JSON=""
SHEETS_POLL_CRON="*/5 * * * *"

# Seed bootstrap super admin
SEED_SUPERADMIN_EMAIL="neeraj@astrasolar.com.au"
SEED_SUPERADMIN_PASSWORD="Nexusadmin0"
SEED_SUPERADMIN_NAME="Neeraj"

# Outbound email (SMTP / nodemailer) — used to send new users their password
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="AstraSolar CRM <no-reply@astrasolar.com.au>"

# ── ClickSend (SMS) ─────────────────────────────────────────────────────────
# REST API credentials from the ClickSend dashboard (Account → API credentials).
CLICKSEND_USERNAME=""
CLICKSEND_API_KEY=""
# System-default alphanumeric sender IDs per brand (3–11 chars). Per-consultant
# overrides in Consultant Contacts take precedence; this is the fallback.
CLICKSEND_SENDER_ID_ASTRA="ASTRASOLAR"
CLICKSEND_SENDER_ID_DC="DCSOLAR"
CLICKSEND_SENDER_ID="ASTRASOLAR"          # last-resort fallback
# Shared secret appended to the delivery-receipt webhook URL as ?token=…
# Configure the same value on the ClickSend "Delivery Receipts" URL:
#   https://<api-host>/api/v1/integrations/clicksend/webhook/delivery?token=…
CLICKSEND_WEBHOOK_TOKEN=""

# ── Aircall (calls) ─────────────────────────────────────────────────────────
# API ID + token from Aircall (Integrations → API Keys). Used for click-to-dial
# and resolving the agent's Aircall user id by email.
AIRCALL_API_ID=""
AIRCALL_API_TOKEN=""
# Default outbound line (Aircall number id) for click-to-dial when not specified.
AIRCALL_DEFAULT_NUMBER_ID=""
# Webhook token: set the same value on the Aircall webhook (sent in the payload)
# or append it as ?token=… on the webhook URL:
#   https://<api-host>/api/v1/integrations/aircall/webhook?token=…
AIRCALL_WEBHOOK_TOKEN=""

# Bloome Google Sheet live sync (see scripts/bloome-sheets-webapp.gs).
# Leave BLOOME_SYNC_URL empty to disable; interval "0" = manual sync only.
BLOOME_SYNC_URL=""
BLOOME_SYNC_TOKEN=""
BLOOME_SYNC_INTERVAL_SECONDS="60"
BLOOME_SYNC_TABS='[{"tab":"ACT:Live","region":"ACT"}]'

# ── Nova (AI assistant) — Anthropic ─────────────────────────────────────────
# Server-side only. Never shipped to the browser. Get from console.anthropic.com.
ANTHROPIC_API_KEY=""
# Model routing (optional overrides)
NOVA_MODEL_SMART="claude-sonnet-4-6"
NOVA_MODEL_FAST="claude-haiku-4-5-20251001"
# Per-user rate limits + cost ceiling
NOVA_RATE_LIMIT_PER_MIN="30"
NOVA_RATE_LIMIT_PER_DAY="500"
NOVA_MAX_TOKENS_CAP="4000"
# Web access — Anthropic server-side web search. Lets Nova answer with live,
# current info (latest rebate changes, news, weather, competitor pricing).
# Executed & billed by Anthropic via ANTHROPIC_API_KEY — no separate search key.
# On by default; set to "off" (or 0/false/no) to disable. Cap searches/turn too.
NOVA_WEB_SEARCH="on"
NOVA_WEB_SEARCH_MAX_USES="5"
# Firebase source for the one-time KB/memory migration (db:nova-migrate).
# Point at the legacy app's service-account JSON + RTDB URL. Leave blank otherwise.
NOVA_MIGRATE_FIREBASE_SERVICE_ACCOUNT_JSON=""
NOVA_MIGRATE_FIREBASE_DATABASE_URL=""

# ── Nova voice (ElevenLabs TTS) — optional ──────────────────────────────────
# If unset, Nova falls back to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=""
NOVA_VOICE_ID="eR40ATw9ArzDf9h3v7t7"     # the original custom NOVA voice
NOVA_TTS_MODEL="eleven_multilingual_v2"

# ── Nova animated avatar (D-ID Agents) — optional ───────────────────────────
# Create an Agent in D-ID Studio (studio.d-id.com) with the Nova presenter image
# and the ElevenLabs Nova voice, then paste its Agent ID + Client Key here.
# If unset, the avatar is hidden and Nova uses voice-only.
DID_AGENT_ID=""
DID_CLIENT_KEY=""
