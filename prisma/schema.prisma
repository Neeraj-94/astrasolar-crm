// ============================================================================
// AstraSolar CRM - Prisma Schema
// PostgreSQL with role + permission-based access control.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Identity
// ----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  firebaseUid  String     @unique
  email        String     @unique
  displayName  String?
  phone        String?
  avatarUrl    String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles        UserRole[]
  auditLogs    AuditLog[]

  // Domain joins (one user may be a Customer, Installer, Consultant, etc.)
  customer     Customer?
  installer    Installer?
  consultant   Consultant?

  // Availability slots where this user IS the consultant whose availability is set
  availabilitySlots AvailabilitySlot[] @relation("ConsultantAvailability")

  @@index([email])
  @@index([firebaseUid])
}

// ----------------------------------------------------------------------------
// RBAC
// ----------------------------------------------------------------------------

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "ceo", "sales_consultant"
  name        String                    // Display name
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "dashboard.leads.view", "leads.update"
  name        String
  description String?
  // Optional grouping helpers — useful for the admin UI.
  dashboard   String?          // e.g. "leads" | "sales" | "ceo" | ...
  tab         String?          // e.g. "overview" | "reports"
  createdAt   DateTime         @default(now())

  roles       RolePermission[]

  @@index([dashboard])
  @@index([dashboard, tab])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())

  role         Role       @relation(fields: [roleId],       references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?  // userId of the admin who granted the role

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ----------------------------------------------------------------------------
// Dashboard / Tab catalog
// Keeps the menu structure in the DB so future dashboards or tabs can be added
// from an admin screen without code changes.
// ----------------------------------------------------------------------------

model Dashboard {
  id           String   @id @default(cuid())
  key          String   @unique // "leads", "sales", "ceo", ...
  name         String
  description  String?
  iconKey      String?  // lucide icon name
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)

  tabs         DashboardTab[]
}

model DashboardTab {
  id            String    @id @default(cuid())
  dashboardId   String
  key           String    // unique per dashboard
  name          String
  description   String?
  sortOrder     Int       @default(0)
  isDefault     Boolean   @default(false)
  isActive      Boolean   @default(true)

  dashboard     Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@unique([dashboardId, key])
}

// ----------------------------------------------------------------------------
// Audit log
// ----------------------------------------------------------------------------

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ROLE_ASSIGN
  ROLE_REVOKE
  PERMISSION_GRANT
  PERMISSION_REVOKE
  STATUS_CHANGE
  PAYMENT
  EXPORT
  OTHER
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String?     // user who took the action
  action      AuditAction
  entityType  String      // "Lead" | "Sale" | "Invoice" | "User" | ...
  entityId    String?
  summary     String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  actor       User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Domain entities (slim — extend later)
// ----------------------------------------------------------------------------

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

model Lead {
  id            String     @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  postcode      String?
  source        String?
  status        LeadStatus @default(NEW)
  ownerUserId   String?    // lead-gen user who owns it
  assignedToId  String?    // sales consultant
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sales         Sale[]

  @@index([status])
  @@index([ownerUserId])
  @@index([assignedToId])
}

enum SaleStatus {
  DRAFT
  PROPOSAL
  CONTRACT_SENT
  SIGNED
  INSTALLED
  CANCELLED
}

model Sale {
  id              String     @id @default(cuid())
  leadId          String?
  consultantId    String?    // consultant user id
  customerId      String?
  systemSizeKw    Decimal?   @db.Decimal(8, 2)
  totalPrice      Decimal?   @db.Decimal(12, 2)
  deposit         Decimal?   @db.Decimal(12, 2)
  status          SaleStatus @default(DRAFT)
  signedAt        DateTime?
  installScheduled DateTime?
  installedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  lead            Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices        Invoice[]

  @@index([status])
  @@index([consultantId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id          String        @id @default(cuid())
  saleId      String
  number      String        @unique
  amount      Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime?
  dueAt       DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  sale        Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Domain "profile" models that link to User
model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique
  address   String?
  postcode  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Installer {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String?
  licenseNo   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Consultant {
  id        String   @id @default(cuid())
  userId    String   @unique
  region    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Consultant availability
// Sparse storage: a row only exists when the default state for a
// (consultant, date, hour) tuple has been explicitly overridden.
// Default state = AVAILABLE during working hours (8..19 local time).
// ----------------------------------------------------------------------------

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

model AvailabilitySlot {
  id           String             @id @default(cuid())
  consultantId String             // User.id of the consultant
  date         DateTime           @db.Date
  hour         Int                // 8..19 — start hour of the 1-hour slot, local time
  status       AvailabilityStatus
  note         String?
  createdById  String?            // user who made the change (audit)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  consultant   User               @relation("ConsultantAvailability", fields: [consultantId], references: [id], onDelete: Cascade)

  @@unique([consultantId, date, hour])
  @@index([date])
  @@index([consultantId, date])
}
